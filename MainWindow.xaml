<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Buff_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Buff_App.ViewModels"
    Title="Buff"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid
            x:Name="AppTitleBar"
            Height="48"
            Background="#0D1012"
            BorderBrush="#1E2226"
            BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo + name -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10" Margin="20,0,0,0">
                <Image
                    Width="36"
                    Height="36"
                    Source="ms-appx:///Assets/AppIcon.ico"
                    Stretch="Uniform" />
                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#EDEDF0" VerticalAlignment="Center" Text="Buff"
                    FontFamily="{StaticResource PixelFont}" />
            </StackPanel>

            <!-- Quit button -->
            <Button
                Grid.Column="1"
                x:Name="QuitButton"
                Padding="14,0"
                VerticalAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Click="QuitButton_Click"
                ToolTipService.ToolTip="Quit Buff">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="12" Glyph="&#xE711;" Foreground="#8A9199" />
                    <TextBlock FontSize="12" Foreground="#8A9199" Text="Quit" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Main two-column layout -->
        <Grid Grid.Row="1" Padding="20,16,20,20" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="Auto" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Network ── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="0" Padding="0,0,12,0">

                    <!-- Hero summary -->
                    <Border Padding="20,16" Margin="0,0,0,12" Background="#111416" BorderBrush="#1E2226" BorderThickness="1" CornerRadius="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#53C028" Text="ACTIVE ROUTE" />
                                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#EDEDF0" Text="{Binding SummaryTitle}" />
                                <TextBlock FontSize="12" Foreground="#8A9199" Text="{Binding SummarySubtitle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="1">
                                <TextBlock FontSize="10" Foreground="#8A9199" HorizontalAlignment="Right" Text="Connected" />
                                <TextBlock FontSize="26" FontWeight="Bold" Foreground="#EDEDF0" HorizontalAlignment="Right" Text="{Binding ConnectedAdapterCount}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Banner -->
                    <InfoBar
                        Margin="0,0,0,12"
                        IsClosable="False"
                        IsOpen="{Binding HasBannerMessage}"
                        Message="{Binding BannerMessage}"
                        Severity="{Binding BannerSeverity}"
                        Title="{Binding BannerTitle}"
                        CornerRadius="10" />

                    <!-- Busy bar -->
                    <ProgressBar Height="2" Margin="0,0,0,10" IsIndeterminate="True" CornerRadius="2"
                        Foreground="#53C028"
                        Opacity="{Binding IsBusy, Converter={StaticResource BooleanToOpacityConverter}}" />

                    <!-- Section label -->
                    <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="#8A9199" Margin="2,0,0,8" Text="NETWORK ADAPTERS" />

                    <!-- Adapter list -->
                    <ItemsControl ItemsSource="{Binding Adapters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:AdapterViewModel">
                                <Border Padding="16,14" Background="#111416" BorderBrush="{x:Bind Info.AccentBorderBrush}" BorderThickness="1" CornerRadius="12">
                                    <Grid RowSpacing="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="5">
                                                <StackPanel Orientation="Horizontal" Spacing="6" FlowDirection="LeftToRight">
                                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#EDEDF0" VerticalAlignment="Center" Text="{x:Bind Info.Name}" />
                                                    <Border Padding="7,2" Background="{x:Bind Info.StatusBadgeBrush}" CornerRadius="5" VerticalAlignment="Center">
                                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#0B0E0F" Text="{x:Bind Info.StatusLabel}" />
                                                    </Border>
                                                    <Border Padding="7,2" Background="#1C2E1A" CornerRadius="5" VerticalAlignment="Center" Visibility="{x:Bind Info.PreferredBadgeVisibility}">
                                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#53C028" Text="Preferred" />
                                                    </Border>
                                                    <Border Padding="7,2" Background="#1A1E22" CornerRadius="5" VerticalAlignment="Center" Visibility="{x:Bind Info.DefaultRouteBadgeVisibility}">
                                                        <TextBlock FontSize="10" Foreground="#8A9199" Text="{x:Bind Info.RouteStatusLabel}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock FontSize="11" Foreground="#8A9199" Text="{x:Bind Info.DetailLine}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Padding="12,7" VerticalAlignment="Center"
                                                Command="{Binding DataContext.SetPrimaryCommand, ElementName=RootGrid}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{x:Bind Info.CanSetPrimary}">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <FontIcon FontSize="11" Glyph="&#xE915;" />
                                                    <TextBlock FontSize="11" Text="{x:Bind Info.ActionLabel}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Grid Grid.Row="1" ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Padding="10,8" Background="#0D1012" CornerRadius="8">
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontSize="8" Foreground="#8A9199" Text="TYPE" />
                                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#EDEDF0" Text="{x:Bind Info.AdapterType}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Padding="10,8" Background="#0D1012" CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock FontSize="8" Foreground="#8A9199" Text="IPv4" />
                                                        <TextBlock FontSize="12" FontWeight="Medium" Foreground="#EDEDF0" Text="{x:Bind IpDisplay, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Width="22" Height="22" Padding="0" VerticalAlignment="Center"
                                                        Background="Transparent" BorderThickness="0" Command="{x:Bind ToggleIpCommand}">
                                                        <FontIcon FontSize="11" Foreground="#8A9199" Glyph="{x:Bind EyeGlyph, Mode=OneWay}" />
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Column="2" Padding="10,8" Background="#0D1012" CornerRadius="8">
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontSize="8" Foreground="#8A9199" Text="METRIC" />
                                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#EDEDF0" Text="{x:Bind Info.MetricDisplay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="3" Padding="10,8" Background="#0D1012" CornerRadius="8">
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontSize="8" Foreground="#8A9199" Text="EFFECTIVE" />
                                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#EDEDF0" Text="{x:Bind Info.EffectiveMetricDisplay}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <Border Padding="24,28" Margin="0,8,0,0" Background="#111416" BorderBrush="#1E2226" BorderThickness="1" CornerRadius="12"
                        Visibility="{Binding EmptyStateVisibility}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon FontSize="24" Foreground="#8A9199" HorizontalAlignment="Center" Glyph="&#xE701;" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#EDEDF0" HorizontalAlignment="Center" Text="No adapters found" />
                            <TextBlock FontSize="12" Foreground="#8A9199" HorizontalAlignment="Center" TextAlignment="Center"
                                Text="Buff could not discover usable network interfaces yet." />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── RIGHT: Speed Test ── -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="10" Padding="0,0,12,0">

                    <!-- Adapter picker -->
                    <Border Padding="14,12" Background="#0F1418" BorderBrush="#1C242C" BorderThickness="1" CornerRadius="14">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="#8A9199" Text="TEST VIA" />
                            <ComboBox
                                ItemsSource="{Binding Adapters}"
                                SelectedItem="{Binding SelectedTestAdapter, Mode=TwoWay}"
                                HorizontalAlignment="Stretch"
                                Background="#0B0F12"
                                BorderBrush="#25303A"
                                CornerRadius="8"
                                Padding="12,8"
                                AutomationProperties.Name="Speed test adapter selector">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:AdapterViewModel">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Padding="6,2" Background="{x:Bind Info.StatusBadgeBrush}" CornerRadius="4" VerticalAlignment="Center">
                                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#0B0E0F" Text="{x:Bind Info.StatusLabel}" />
                                            </Border>
                                            <TextBlock FontSize="13" FontWeight="Medium" Foreground="#EDEDF0" VerticalAlignment="Center" Text="{x:Bind Info.Name}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Fast-style hero speed card -->
                    <Border Height="430" Padding="22,18" CornerRadius="16" BorderThickness="1" BorderBrush="#21303A">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D1318" Offset="0" />
                                <GradientStop Color="#111A20" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Spacing="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#53C028" HorizontalAlignment="Center" Text="YOUR INTERNET SPEED" />

                            <StackPanel Spacing="2" HorizontalAlignment="Center">
                                <TextBlock FontSize="11" Foreground="#8A9199" HorizontalAlignment="Center" Text="{Binding SpeedDisplayPhaseLabel}" />
                                <TextBlock
                                    FontSize="62"
                                    FontWeight="SemiBold"
                                    Foreground="#EDEDF0"
                                    HorizontalAlignment="Center"
                                    Text="{Binding SpeedDisplayValue}" />
                                <TextBlock FontSize="16" Foreground="#8A9199" HorizontalAlignment="Center" Text="Mbps" />
                            </StackPanel>

                            <TextBlock Height="24" FontSize="13" Foreground="#95A0A9" Text="{Binding SpeedTestStatusTitle}" TextAlignment="Center" />
                            <TextBlock Height="42" FontSize="12" Foreground="#7F8A92" Text="{Binding SpeedTestStatusMessage}" TextAlignment="Center" TextWrapping="WrapWholeWords" MaxWidth="320" />

                            <Button
                                Width="220"
                                HorizontalAlignment="Center"
                                Padding="0,12"
                                CornerRadius="28"
                                Background="#53C028"
                                Foreground="#0B0F0E"
                                Command="{Binding RunSpeedTestCommand}"
                                AutomationProperties.Name="Run speed test">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon FontSize="14" Glyph="&#xE768;" />
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="Check" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Speedtest-style metrics -->
                    <Grid Visibility="{Binding SpeedResultGridVisibility}" ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Visibility="{Binding DownloadResultVisibility}" Padding="14,12" Background="#10171C" BorderBrush="#1F2A33" BorderThickness="1" CornerRadius="12">
                            <StackPanel Spacing="3">
                                <TextBlock FontSize="9" Foreground="#7F8A92" Text="DOWNLOAD" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#53C028" Text="{Binding LatestSpeedTestResult.DownloadDisplay}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Visibility="{Binding UploadResultVisibility}" Padding="14,12" Background="#10171C" BorderBrush="#1F2A33" BorderThickness="1" CornerRadius="12">
                            <StackPanel Spacing="3">
                                <TextBlock FontSize="9" Foreground="#7F8A92" Text="UPLOAD" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#EDEDF0" Text="{Binding LatestSpeedTestResult.UploadDisplay}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Visibility="{Binding AdditionalResultVisibility}" Padding="14,12" Background="#10171C" BorderBrush="#1F2A33" BorderThickness="1" CornerRadius="12">
                            <StackPanel Spacing="3">
                                <TextBlock FontSize="9" Foreground="#7F8A92" Text="PING" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#EDEDF0" Text="{Binding LatestSpeedTestResult.PingDisplay}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Visibility="{Binding AdditionalResultVisibility}" Padding="14,12" Background="#10171C" BorderBrush="#1F2A33" BorderThickness="1" CornerRadius="12">
                            <StackPanel Spacing="3">
                                <TextBlock FontSize="9" Foreground="#7F8A92" Text="JITTER" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#EDEDF0" Text="{Binding LatestSpeedTestResult.JitterDisplay}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Connection details -->
                    <Border Visibility="{Binding AdditionalResultVisibility}" Padding="14,12" Background="#0F1418" BorderBrush="#1C242C" BorderThickness="1" CornerRadius="12">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock FontSize="9" Foreground="#7F8A92" Text="ISP" />
                                <TextBlock FontSize="11" FontWeight="Medium" Foreground="#EDEDF0" Text="{Binding LatestSpeedTestResult.IspName}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock FontSize="9" Foreground="#7F8A92" Text="SERVER" />
                                <TextBlock FontSize="11" FontWeight="Medium" Foreground="#EDEDF0" Text="{Binding LatestSpeedTestResult.ServerName}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock FontSize="11" Foreground="#4A5159" HorizontalAlignment="Center" Text="Powered by M-Lab NDT7 over secure WebSockets." />

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
